{
  "compilerOptions": {
    // Target y módulos para Node
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],

    // Carpeta de salida
    "outDir": "./dist",
    "rootDir": ".",

    // Metadatos necesarios para TypeORM
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    // Configuración menos estricta para testing
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,

    // Mapas de fuente y declaraciones
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Compatibilidad con Node
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Resolución de módulos
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "allowJs": true,

    // Tipos para testing
    "types": ["node", "jest", "jsonwebtoken"]
  },
  "include": ["src/**/*", "tests/**/*"],
  "exclude": ["node_modules", "dist", "coverage"]
}
